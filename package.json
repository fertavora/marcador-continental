{
  "name": "marcador-continental",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@marcador/mobile": {
      "tailwindcss": "^3.4.19"
    }
  },
  "scripts": {
    "dev": "npm run dev --workspace=@marcador/web",
    "build": "npm run build --workspace=@marcador/web",
    "start": "npm run start --workspace=@marcador/web",
    "lint": "npm run lint --workspace=@marcador/web",
    "mobile": "npm run start --workspace=@marcador/mobile",
    "mobile:android": "npm run android --workspace=@marcador/mobile"
  }
}
